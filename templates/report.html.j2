<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Monthly Review — {{ month_name }} {{ params.year }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #0d0d0d;
      color: #e0e0e0;
      line-height: 1.5;
    }

    /* ── Header ─────────────────────────────────────────────── */
    header {
      background: #111;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .header-logo {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .header-logo-bar {
      width: 4px;
      height: 36px;
      background: linear-gradient(180deg, #FFE600, #009EE3);
      border-radius: 2px;
    }
    .header-title h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.3px;
    }
    .header-title p { font-size: 0.85rem; color: #666; margin-top: 2px; }
    .header-period {
      background: rgba(255,230,0,0.08);
      border: 1px solid rgba(255,230,0,0.2);
      border-radius: 12px;
      padding: 10px 22px;
      text-align: center;
    }
    .period-month { font-size: 1.3rem; font-weight: 800; color: #FFE600; }
    .period-year  { font-size: 0.8rem; color: #888; margin-top: 1px; }

    /* ── Nav ────────────────────────────────────────────────── */
    nav {
      background: #111;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 48px;
      display: flex;
      align-items: center;
      gap: 2px;
    }
    nav a {
      display: inline-block;
      padding: 13px 16px;
      text-decoration: none;
      color: #666;
      font-size: 0.85rem;
      font-weight: 500;
      border-bottom: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s;
    }
    nav a:hover        { color: #FFE600; border-bottom-color: #FFE600; }
    nav .nav-home      { color: #444; font-size: 0.8rem; }
    nav .nav-home:hover { color: #888; border-bottom-color: transparent; }

    /* ── Layout ─────────────────────────────────────────────── */
    .container { max-width: 1280px; margin: 36px auto; padding: 0 28px; }

    /* ── Section ────────────────────────────────────────────── */
    .section { margin-bottom: 56px; }
    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #FFE600;
      background: rgba(255,230,0,0.08);
      border: 1px solid rgba(255,230,0,0.2);
      border-radius: 20px;
      padding: 3px 12px;
    }
    .section-title { font-size: 1.15rem; font-weight: 700; color: #fff; }
    .section-count { font-size: 0.75rem; color: #555; background: #1a1a1a; border-radius: 20px; padding: 2px 10px; margin-left: auto; }

    /* ── Query cards ─────────────────────────────────────────── */
    .query-card {
      background: #141414;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.07);
      margin-bottom: 16px;
      overflow: hidden;
      position: relative;
    }
    .query-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #FFE600, #009EE3);
    }
    .query-card-header { padding: 20px 24px 16px; }
    .query-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .query-description { font-size: 0.82rem; color: #666; margin-top: 4px; }
    .query-file        { font-size: 0.72rem; color: #3a3a3a; margin-top: 5px; font-family: monospace; }

    .badge {
      font-size: 0.65rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 20px;
    }
    .badge-error   { background: rgba(220,38,38,0.12); color: #f87171; border: 1px solid rgba(220,38,38,0.25); }
    .badge-dry-run { background: rgba(255,230,0,0.08); color: #FFE600; border: 1px solid rgba(255,230,0,0.2); }

    /* ── Chart area ──────────────────────────────────────────── */
    .chart-area {
      padding: 0 24px 20px;
      position: relative;
    }
    .chart-area canvas { max-height: 300px; }

    /* ── Table toggle ────────────────────────────────────────── */
    .table-toggle {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 24px;
      font-size: 0.75rem;
      color: #555;
      cursor: pointer;
      user-select: none;
      border-top: 1px solid rgba(255,255,255,0.05);
      transition: color 0.15s;
    }
    .table-toggle:hover { color: #888; }
    .table-toggle-arrow { transition: transform 0.2s; font-size: 0.6rem; }
    .table-toggle.open .table-toggle-arrow { transform: rotate(180deg); }
    .table-collapsible { display: none; }
    .table-collapsible.open { display: block; }

    /* ── Tables ──────────────────────────────────────────────── */
    .table-wrapper { overflow-x: auto; padding: 0 24px 20px; }
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    }
    .data-table thead th {
      background: #1a1a1a;
      padding: 9px 14px;
      text-align: left;
      font-weight: 600;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #555;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      white-space: nowrap;
    }
    .data-table tbody td {
      padding: 9px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: #ccc;
    }
    .data-table tbody tr:last-child td { border-bottom: none; }
    .data-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .data-table tbody td:first-child { font-weight: 500; color: #e0e0e0; }
    .data-table td:not(:first-child) { text-align: right; }
    .data-table th:not(:first-child) { text-align: right; }

    /* ── States ──────────────────────────────────────────────── */
    .no-data { color: #444; font-size: 0.85rem; padding: 20px 24px; }
    .error {
      color: #f87171; font-size: 0.82rem;
      padding: 12px 16px; margin: 0 24px 20px;
      background: rgba(220,38,38,0.08);
      border: 1px solid rgba(220,38,38,0.2);
      border-radius: 8px;
    }
    .dry-run {
      color: #888; font-size: 0.82rem;
      padding: 12px 16px; margin: 0 24px 20px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 8px;
    }

    /* ── Footer ──────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 32px 24px;
      color: #3a3a3a;
      font-size: 0.78rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 32px;
    }
    footer a { color: #555; text-decoration: none; }
    footer a:hover { color: #888; }

    @media (max-width: 640px) {
      header, nav { padding-left: 16px; padding-right: 16px; }
      .container { padding: 0 16px; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-logo">
    <div class="header-logo-bar"></div>
    <div class="header-title">
      <h1>Monthly Review</h1>
      <p>Negocio · Producto · CX</p>
    </div>
  </div>
  <div class="header-period">
    <div class="period-month">{{ month_name }}</div>
    <div class="period-year">{{ params.year }}</div>
  </div>
</header>

<nav>
  <a href="../../index.html" class="nav-home">← Todos</a>
  {% for section_key in sections.keys() %}
  <a href="#{{ section_key }}">{{ section_labels.get(section_key, section_key | title) }}</a>
  {% endfor %}
</nav>

<div class="container">

  {% set section_labels_map = {"business": "Negocio", "product": "Producto", "cx": "CX"} %}

  {% for section_key, items in sections.items() %}
  <section class="section" id="{{ section_key }}">
    <div class="section-header">
      <span class="section-label">{{ section_key | upper }}</span>
      <span class="section-title">{{ section_labels.get(section_key, section_key | title) }}</span>
      <span class="section-count">{{ items | length }} metricas</span>
    </div>

    {% for item in items %}
    {% set card_id = section_key ~ '_' ~ loop.index %}
    <div class="query-card">
      <div class="query-card-header">
        <div class="query-title">
          {{ item.title }}
          {% if item.status == 'error' %}<span class="badge badge-error">Error</span>{% endif %}
        </div>
        {% if item.description %}<div class="query-description">{{ item.description }}</div>{% endif %}
        <div class="query-file">{{ item.file }}</div>
      </div>

      {# ── Chart ─────────────────────────────────────────────── #}
      {% if item.chart_type and item.df_json %}
      <div class="chart-area">
        <canvas id="chart-{{ card_id }}"></canvas>
      </div>
      <script>
        window.__CHARTS = window.__CHARTS || {};
        window.__CHARTS["chart-{{ card_id }}"] = {
          type: {{ item.chart_type | tojson }},
          data: {{ item.df_json | safe }}
        };
      </script>
      {# Show table collapsed when chart exists #}
      <div class="table-toggle" onclick="toggleTable('{{ card_id }}')">
        <span class="table-toggle-arrow" id="arrow-{{ card_id }}">▼</span>
        Ver tabla de datos
      </div>
      <div class="table-collapsible" id="tbl-{{ card_id }}">
        <div class="table-wrapper">{{ item.table_html | safe }}</div>
      </div>
      {% else %}
      {# ── Plain table ───────────────────────────────────────── #}
      <div class="table-wrapper">{{ item.table_html | safe }}</div>
      {% endif %}

    </div>
    {% endfor %}

  </section>
  {% endfor %}

</div>

<footer>
  Periodo: {{ params.start_date }} &rarr; {{ params.end_date }} &nbsp;&middot;&nbsp;
  Generado el {{ generated_at }} &nbsp;&middot;&nbsp;
  <a href="../../index.html">Ver todos los reportes</a>
</footer>

<script>
Chart.register(ChartDataLabels);

// ── Palette ──────────────────────────────────────────────────────────────────
const PAL = ['#FFE600','#009EE3','#FF5252','#00C853','#FF9800','#9C27B0','#00BCD4'];
const PAL_ALPHA = (hex, a) => {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
};

const CHART_DEFAULTS = {
  color: '#888',
  plugins: { legend: { labels: { color: '#888', boxWidth: 12, padding: 16 } } },
  scales: {
    x: { ticks: { color: '#666' }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'rgba(255,255,255,0.07)' } },
    y: { ticks: { color: '#666' }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'rgba(255,255,255,0.07)' } }
  }
};

// ── Helpers ───────────────────────────────────────────────────────────────────
function numericCols(row) {
  return Object.keys(row).filter(k => typeof row[k] === 'number' && isFinite(row[k]));
}

// ── CES color map ─────────────────────────────────────────────────────────────
const CES_COLORS = { 'facil': '#FFE600', 'neutro': '#888888', 'dificil': '#3d3d3d' };
function cesColor(colName, idx) {
  const k = colName.toLowerCase().replace(/[^a-z]/g, '');
  for (const [key, val] of Object.entries(CES_COLORS)) {
    if (k.includes(key)) return val;
  }
  return PAL[idx % PAL.length];
}

// ── Chart renderers ───────────────────────────────────────────────────────────
function renderBarGrouped(ctx, data) {
  const cols = Object.keys(data[0]);
  const labelCol = cols[0];
  const valCols  = numericCols(data[0]).filter(c => !c.toLowerCase().includes('respuestas'));

  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: data.map(r => r[labelCol]),
      datasets: valCols.map((col, i) => ({
        label: col,
        data: data.map(r => r[col] ?? null),
        backgroundColor: cesColor(col, i),
        borderRadius: 5,
        maxBarThickness: 40,
      }))
    },
    options: {
      responsive: true,
      plugins: {
        legend: CHART_DEFAULTS.plugins.legend,
        datalabels: {
          anchor: 'end', align: 'end',
          color: '#bbb', font: { size: 11, weight: '600' },
          formatter: v => v != null ? v + '%' : ''
        }
      },
      scales: {
        x: CHART_DEFAULTS.scales.x,
        y: { ...CHART_DEFAULTS.scales.y, min: 0, max: 105, ticks: { callback: v => v + '%', color: '#666' } }
      }
    }
  });
}

function renderDoughnut(ctx, data) {
  const cols   = Object.keys(data[0]);
  const lblCol = cols[0];
  const valCol = numericCols(data[0])[0];

  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: data.map(r => r[lblCol]),
      datasets: [{
        data: data.map(r => r[valCol] ?? 0),
        backgroundColor: PAL.slice(0, data.length),
        borderWidth: 0,
        hoverOffset: 6,
      }]
    },
    options: {
      responsive: true,
      cutout: '62%',
      plugins: {
        legend: { position: 'right', labels: { color: '#888', boxWidth: 12, padding: 14 } },
        datalabels: {
          color: '#fff', font: { size: 12, weight: '700' },
          formatter: (v, ctx) => {
            const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
            return total ? (v / total * 100).toFixed(1) + '%' : '';
          }
        }
      }
    }
  });
}

function renderBarHorizontal(ctx, data) {
  const cols    = Object.keys(data[0]);
  const lblCol  = cols[0];
  const valCols = numericCols(data[0]).filter(c => c.toLowerCase().includes('promedio') || c.toLowerCase().includes('min'));

  const col = valCols[0] || numericCols(data[0])[0];
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: data.map(r => r[lblCol]),
      datasets: [{
        label: col,
        data: data.map(r => r[col] ?? null),
        backgroundColor: PAL[0],
        borderRadius: 5,
        maxBarThickness: 32,
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      plugins: {
        legend: { display: false },
        datalabels: {
          anchor: 'end', align: 'right',
          color: '#aaa', font: { size: 11, weight: '600' },
          formatter: v => v != null ? v + ' min' : ''
        }
      },
      scales: {
        x: { ...CHART_DEFAULTS.scales.x, ticks: { callback: v => v + ' min', color: '#666' } },
        y: CHART_DEFAULTS.scales.y
      }
    }
  });
}

function renderBarMonthly(ctx, data) {
  // Multi-series: group by Mes, one series per Pais+Canal
  const mesSet  = [...new Set(data.map(r => r.Mes  || r.mes))];
  const serieSet = [...new Set(data.map(r => (r.Pais || r.pais) + ' ' + (r.Canal || r.canal)))];
  const metricCol = ['Pct_Open_Rate','abiertos','Abiertos'].find(c => data[0][c] !== undefined) || 'Abiertos';

  const datasets = serieSet.map((serie, i) => {
    const [pais, canal] = serie.split(' ');
    return {
      label: serie,
      data: mesSet.map(mes => {
        const row = data.find(r =>
          (r.Mes || r.mes) === mes &&
          (r.Pais || r.pais) === pais &&
          (r.Canal || r.canal) === canal
        );
        return row ? (row[metricCol] ?? null) : null;
      }),
      backgroundColor: PAL[i % PAL.length],
      borderRadius: 4,
      maxBarThickness: 24,
    };
  });

  new Chart(ctx, {
    type: 'bar',
    data: { labels: mesSet, datasets },
    options: {
      responsive: true,
      plugins: {
        legend: CHART_DEFAULTS.plugins.legend,
        datalabels: { display: false }
      },
      scales: {
        x: CHART_DEFAULTS.scales.x,
        y: CHART_DEFAULTS.scales.y
      }
    }
  });
}

// ── Init all charts ───────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const charts = window.__CHARTS || {};
  Object.entries(charts).forEach(([id, cfg]) => {
    const ctx = document.getElementById(id);
    if (!ctx || !cfg.data || !cfg.data.length) return;
    try {
      if      (cfg.type === 'bar_grouped')  renderBarGrouped(ctx, cfg.data);
      else if (cfg.type === 'doughnut')     renderDoughnut(ctx, cfg.data);
      else if (cfg.type === 'bar_horizontal') renderBarHorizontal(ctx, cfg.data);
      else if (cfg.type === 'bar_monthly')  renderBarMonthly(ctx, cfg.data);
    } catch(e) { console.error('Chart error for', id, e); }
  });
});

// ── Table toggle ──────────────────────────────────────────────────────────────
function toggleTable(id) {
  const tbl   = document.getElementById('tbl-' + id);
  const arrow = document.getElementById('arrow-' + id);
  const toggle = arrow.closest('.table-toggle');
  if (!tbl) return;
  tbl.classList.toggle('open');
  toggle.classList.toggle('open');
}
</script>

</body>
</html>
